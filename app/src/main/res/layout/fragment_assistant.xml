<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#F9FBFC">

    <TextView
        android:id="@+id/tv_today_accumulated_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today Target"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A1C1E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/> 
    
    <TextView
        android:id="@+id/tv_status_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Please set target..."
        android:textSize="15sp"
        android:textColor="#6C7074"
        app:layout_constraintTop_toBottomOf="@id/tv_today_accumulated_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp"/>

    <LinearLayout
        android:id="@+id/layout_dual_circles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="40dp" 
        app:layout_constraintTop_toBottomOf="@id/tv_status_hint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textColor="#43474E"
                android:layout_marginBottom="10dp"/>
            <FrameLayout
                android:layout_width="125dp"
                android:layout_height="125dp">
                <ProgressBar
                    android:id="@+id/progress_circle_time"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_background"
                    android:progressDrawable="@drawable/circle_progress"
                    android:max="100"
                    android:progress="0" />
                <TextView
                    android:id="@+id/tv_time_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="0%"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tv_time_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginTop="10dp"/>
            <TextView
                android:id="@+id/tv_time_target"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / --:--"
                android:textSize="13sp"
                android:textColor="#73777F"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Distance"
                android:textSize="25sp"
                android:textStyle="bold"
                android:textColor="#43474E"
                android:layout_marginBottom="10dp"/>
            <FrameLayout
                android:layout_width="125dp"
                android:layout_height="125dp">
                <ProgressBar
                    android:id="@+id/progress_circle_distance"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_background"
                    android:progressDrawable="@drawable/circle_progress"
                    android:max="100"
                    android:progress="0" />
                <TextView
                    android:id="@+id/tv_distance_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="0%"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#0277BD"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tv_distance_current"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#0277BD"
                android:layout_marginTop="10dp"/>
            <TextView
                android:id="@+id/tv_distance_target"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / --.-- km"
                android:textSize="13sp"
                android:textColor="#73777F"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_feature_cards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/layout_dual_circles"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_fall_detection"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Status"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E"/>
                <TextView
                    android:id="@+id/tv_pose_reminder_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STOP"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_calories"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calories"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A1C1E"/>
                <TextView
                    android:id="@+id/tv_calories_burnt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 kcal"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_reset_target"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reset Target"
        android:textSize="14sp"
        android:textColor="#43474E"
        app:backgroundTint="#EFF0F3"
        app:cornerRadius="10dp"
        app:layout_constraintTop_toBottomOf="@id/layout_feature_cards"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <LinearLayout
    android:id="@+id/layout_history_section"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:orientation="vertical"
    android:layout_marginTop="16dp"
    android:layout_marginBottom="16dp"
    app:layout_constraintTop_toBottomOf="@id/btn_reset_target"
    app:layout_constraintBottom_toTopOf="@+id/btn_start_stop"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 歷史紀錄 (最近10筆)"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#43474E"/>

        <Button
            android:id="@+id/btn_clear_history"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:text="🧹 清空"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            app:backgroundTint="#F5F5F5"
            android:textColor="#D32F2F"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:elevation="1dp">
        
        <LinearLayout
            android:id="@+id/container_history_records"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>
    </ScrollView>
</LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_start_stop"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:text="START"
        android:textSize="22sp"
        android:textStyle="bold"
        android:backgroundTint="#2E7D32"
        android:textColor="@android:color/white"
        app:cornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"
        app:layout_constraintWidth_percent="0.95" />

</androidx.constraintlayout.widget.ConstraintLayout>